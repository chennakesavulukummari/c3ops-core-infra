# C3OPS.io Terraform Configuration
# Copy this file to terraform.tfvars and update with your values

aws_region   = "ap-south-2"
environment  = "production"
project_name = "c3ops-website"
domain_name  = "c3ops.io"

# ACM Certificate ARN (must be in us-east-1 for CloudFront)
# Create certificate first: aws acm request-certificate --domain-name c3ops.io --subject-alternative-names "*.c3ops.io" --region us-east-1
certificate_arn = "arn:aws:acm:us-east-1:318095823459:certificate/YOUR-CERT-ID"

# Lambda settings
lambda_memory   = 256
lambda_timeout  = 30

# DynamoDB settings
dynamodb_billing_mode = "PAY_PER_REQUEST"

# Logging
enable_cloudwatch_logs = true
log_retention_days     = 30

# Tags
tags = {
  Owner       = "C3OPS"
  CostCenter  = "Engineering"
  Compliance  = "SOC2"
}

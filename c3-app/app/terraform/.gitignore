# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan

# Ignore lock file (optional - recommend committing for team projects)
# .terraform.lock.hcl

# OS files
.DS_Store
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.iml

# Logs
*.log

# Temp files
*.tmp

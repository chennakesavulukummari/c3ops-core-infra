###############################################################################
# C3OPS CORE INFRASTRUCTURE - .gitignore
# This file prevents sensitive data from being accidentally committed to Git
###############################################################################

###############################################################################
# TERRAFORM - Infrastructure as Code
###############################################################################
# Local .terraform directories
.terraform/
.terraform.lock.hcl

# .tfstate files (contain resource state and sensitive data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files containing sensitive data:
# - passwords
# - private keys
# - API keys
# - AWS credentials
*.tfvars
*.tfvars.json

# Terraform override files (local customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock info
.terraform.tfstate.lock.info

# CLI configuration files
.terraformrc
terraform.rc

###############################################################################
# ENVIRONMENT VARIABLES & SECRETS
###############################################################################
# Environment files (contain API keys, passwords, credentials)
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.test.local
.env.staging.local

# AWS Credentials
.aws/
~/.aws/credentials
~/.aws/config

###############################################################################
# AWS & CLOUD CREDENTIALS
###############################################################################
# AWS credential files (when accidentally committed to repo)
aws-credentials.txt
aws-creds.md
aws-secret.md
*-creds.md
*-secret.md
*-password.md
*-credentials.md

# CloudFormation outputs
cfn-outputs.json
stack-outputs.json

###############################################################################
# NODE.JS / NPM
###############################################################################
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Production build output
dist/
build/
out/
.next/

# Lock files (optional - include for reproducible installs)
# Uncomment if you want to track lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Node modules archives
*.tgz
*.tar.gz

###############################################################################
# IDE & EDITOR FILES
###############################################################################
# VS Code
.vscode/
*.code-workspace
.vs/

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

###############################################################################
# PRIVATE KEYS & CERTIFICATES
###############################################################################
# SSH keys
*.pem
*.key
*.ppk
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
.ssh/

# SSL Certificates
*.cert
*.crt
*.p12
*.pfx

# PGP/GPG keys
*.gpg

###############################################################################
# DEPLOYMENT & BUILD ARTIFACTS
###############################################################################
# Lambda deployment packages
lambda-*.zip
function-*.zip
*.zip
!source.zip

# SAM/CloudFormation builds
.aws-sam/
sam-tests/

# Terraform plans
*.tfplan
plan.out

# Build artifacts
target/
.gradle/
.cache/

###############################################################################
# LOGS & TEMPORARY FILES
###############################################################################
# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# Temporary files
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# System files
.vimrc
.bash_history

###############################################################################
# DATABASE & CACHE
###############################################################################
# Database files
*.db
*.sqlite
*.sqlite3
*.sqliterc

# Cache directories
.cache/
cache/

###############################################################################
# LOCAL DEVELOPMENT
###############################################################################
# Local development overrides
local/
.local/
.env.local

# Testing
.coverage
coverage/
.nyc_output/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

###############################################################################
# SENSITIVE DOCUMENTATION
###############################################################################
# Files with sensitive information
*-creds.md
*-secret.md
*-password.md
credentials.md
secrets.md
CREDENTIALS.md
SECRETS.md

###############################################################################
# ROUTE53 & DNS SENSITIVE INFO
###############################################################################
# Route53 hosted zone files
*-zone-id.txt
*-nameservers.txt
zone-ids.md
dns-records.md

###############################################################################
# GITHUB ACTIONS & CI/CD
###############################################################################
# GitHub Actions secrets
.github/workflows/secrets.json
.github/credentials.yml

# CI/CD logs
ci-cd-logs/
pipeline-logs/

###############################################################################
# DOCKER & CONTAINER FILES
###############################################################################
.docker/
docker-compose.override.yml
.dockerignore

###############################################################################
# BACKUP FILES
###############################################################################
# Backup files
*.backup
*.bak
*.backup.*
*.orig
*backup/
backups/

# Archive files
*.tar
*.tar.gz
*.rar
*.7z

###############################################################################
# PLATFORM-SPECIFIC
###############################################################################
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*/

###############################################################################
# PROJECT-SPECIFIC SENSITIVE FILES
###############################################################################
# C3OPS specific
c3ops-credentials.json
c3ops-secrets.env
typeform-*.env
lambda-env.json

###############################################################################
# DO NOT IGNORE THESE (use ! prefix to allow)
###############################################################################
# Allow example/template files
!.env.example
!.env.*.example
!terraform.tfvars.example
!*-example.json
!*-template.*
!.gitignore
